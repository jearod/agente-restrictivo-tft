pipeline {
    // Ejecutar el pipeline en cualquier agente de Jenkins disponible
    agent any

    // Opciones globales del pipeline
    options {
        buildDiscarder(logRotator(numToKeepStr: '5')) // Mantiene solo los últimos 5 logs para no llenar el disco
        disableConcurrentBuilds() // Evita que dos pipelines choquen si haces muchos commits rápidos
    }

    // Variables de entorno
    environment {
        DOCKER_IMAGE_NAME = "agente-tft-env"
        WORKSPACE_PATH = "${WORKSPACE}"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "📥 1. Obteniendo la última versión del código desde GitHub..."
                checkout scm
            }
        }

        stage('Build Docker Environment') {
            steps {
                echo "🏗️ 2. Construyendo el entorno hermético (Dockerfile - Grado R1)..."
                script {
                    // Usamos la raíz (.) como contexto, pero apuntamos al Dockerfile en su nueva ruta
                    sh "docker build -t ${DOCKER_IMAGE_NAME} -f docker/Dockerfile ."
                }
            }
        }

        stage('Train Model') {
            steps {
                echo "🧠 3. Ejecutando el pre-entrenamiento global (src.main)..."
                script {
                    // Montamos el workspace para que el modelo entrenado (.ckpt) se guarde en Jenkins
                    // Sobrescribimos la URL de MLflow para que guarde localmente en la carpeta mlruns
                    sh """
                    docker run --rm \
                    -e MLFLOW_TRACKING_URI=http://mlflow_server:5000 \
                    ${DOCKER_IMAGE_NAME} \
                    python3 -m src.main
                    """
                }
            }
        }

        stage('Evaluate Agent') {
            steps {
                echo "📊 4. Evaluando el Agente Restrictivo (F1-Score y MDD)..."
                script {
                    // Ejecutamos el script de evaluación que acabamos de crear
                    sh """
                    docker run --rm \
                    ${DOCKER_IMAGE_NAME} \
                    python3 -m src.evaluate
                    """
                }
            }
        }
    }

    // Acciones al finalizar (sin importar si falló o fue exitoso)
    post {
        success {
            echo "✅ Pipeline CI/CD completado con éxito. El Agente Restrictivo ha sido validado."
        }
        failure {
            echo "❌ El pipeline ha fallado. Revisa los logs de la consola en Jenkins."
        }
        always {
            echo "🧹 Limpiando caché de imágenes Docker residuales..."
            sh "docker image prune -f || true"
        }
    }
}