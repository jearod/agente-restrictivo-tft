pipeline {
    agent any

    parameters {
        booleanParam(name: 'RUN_MASS_INFERENCE', defaultValue: false, description: '¿Ejecutar la validación masiva con los 500+ ETFs?')
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '5'))
        disableConcurrentBuilds()
        timestamps() 
    }

    environment {
        DOCKER_IMAGE_NAME = "agente-tft-env"
    }

    stages {
        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Build Docker Environment') {
            steps {
                echo "🏗️ Construyendo imagen y horneando los datos (etf.zip) dentro de ella..."
                sh "docker build --no-cache -t ${DOCKER_IMAGE_NAME} -f docker/Dockerfile ."
            }
        }

        stage('Start Execution Environment') {
            steps {
                sh "docker rm -f tft_execution || true"
                // NOTA: Eliminamos el -v. El contenedor ya tiene todo adentro.
                sh "docker run -d --name tft_execution --network host -e MLFLOW_TRACKING_URI=http://localhost:5000 ${DOCKER_IMAGE_NAME} tail -f /dev/null"
            }
        }

        // NUEVA FASE: Descomprimir los datos usando Python nativo
        stage('Phase 0: Prepare Data') {
            steps {
                echo "📦 Extrayendo corpus de ETFs (pretrain y raw)..."
                // Usamos shutil de Python para extraer el zip dentro de la carpeta data/
                sh "docker exec tft_execution python3 -c \"import shutil; shutil.unpack_archive('data/etf.zip', 'data/')\""
                // Verificamos rápidamente que las carpetas se crearon bien
                sh "docker exec tft_execution ls -la data/"
            }
        }

        stage('Phase 1: Train Model') {
            steps {
                echo "🧠 Entrenando modelo TFT..."
                sh "docker exec tft_execution python3 -m src.main"
            }
        }

        stage('Phase 2: Evaluate Agent') {
            steps {
                echo "📊 Evaluando modelo base (F1 y MDD)..."
                sh "docker exec tft_execution python3 -m src.evaluate"
            }
        }

        stage('Phase 3: Mass Inference') {
            when {
                expression { params.RUN_MASS_INFERENCE == true }
            }
            steps {
                echo "🚀 Ejecutando inferencia masiva en 500+ ETFs..."
                sh "docker exec tft_execution python3 -m src.mass_inference"
            }
        }

        stage('Extract Artifacts') {
            when {
                expression { params.RUN_MASS_INFERENCE == true }
            }
            steps {
                sh "docker cp tft_execution:/app/data/processed/mass_inference_results.csv ./mass_inference_results.csv || true"
                archiveArtifacts artifacts: 'mass_inference_results.csv', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            echo "🧹 Destruyendo contenedor y limpiando..."
            sh "docker rm -f tft_execution || true"
            sh "docker image prune -f || true"
        }
    }
}